{
    "name": "querri/embed",
    "description": "PHP SDK for embedding Querri analytics into your application",
    "type": "library",
    "license": "MIT",
    "keywords": ["querri", "embed", "analytics", "sdk"],
    "homepage": "https://github.com/Querri-inc/querri-phpembed",
    "authors": [
        { "name": "Querri", "homepage": "https://querri.com" }
    ],
    "support": {
        "issues": "https://github.com/Querri-inc/querri-phpembed/issues",
        "source": "https://github.com/Querri-inc/querri-phpembed"
    },
    "require": {
        "php": "^8.3",
        "symfony/http-client": "^7.2",
        "ext-json": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Querri\\Embed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Querri\\Embed\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "echo 'No tests yet — see https://github.com/Querri-inc/querri-phpembed/issues'",
        "analyse": "phpstan analyse --memory-limit=512M",
        "version": "php scripts/bump-version.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
