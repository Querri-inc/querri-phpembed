{
    "name": "querri/embed",
    "description": "PHP SDK for embedding Querri analytics into your application",
    "type": "library",
    "license": "MIT",
    "keywords": ["querri", "embed", "analytics", "sdk"],
    "homepage": "https://github.com/Querri-inc/querri-phpembed",
    "require": {
        "php": "^8.3",
        "symfony/http-client": "^7.2",
        "ext-json": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Querri\\Embed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Querri\\Embed\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "echo 'No tests yet — see https://github.com/Querri-inc/querri-phpembed/issues'",
        "bump": "php scripts/bump-version.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
